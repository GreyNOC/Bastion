# GreyNOC Bastion — environment configuration
# Copy to .env and adjust. Every default below is the safe, local-first default.
# Bastion also reads these as real environment variables (env vars win over .env).

# --- Network / API binding ---
# Local API and dashboard binding. Keep on loopback unless you fully understand
# the exposure implications of changing it.
BASTION_HOST=127.0.0.1
BASTION_PORT=8788

# --- Dashboard remote access (fail-closed) ---
# The dashboard binds to loopback only by default. Binding to a non-loopback
# host is REFUSED unless BOTH of the following are set. Do not expose an
# unauthenticated dashboard.
BASTION_ALLOW_REMOTE_DASHBOARD=0
# A strong random token. When set, every dashboard request must carry
# `Authorization: Bearer <token>` (header preferred; ?token= allowed for local
# dev). Required for any remote bind.
BASTION_DASHBOARD_TOKEN=
# Optional: pin the Flask session-signing key so sessions survive a restart.
# Leave empty for a fresh per-process key.
BASTION_WEB_SECRET=

# --- Data locations ---
# SQLite database and report output. Relative paths resolve against the
# Bastion home directory (default: ~/.greynoc-bastion).
BASTION_HOME=
BASTION_DB_PATH=bastion.db
BASTION_REPORT_DIR=reports

# --- Live fetching (threat feeds) ---
# OFF by default. When enabled: HTTPS only, allowlisted hosts only,
# response-size and timeout caps, redirect validation, private/loopback
# hosts always blocked.
BASTION_LIVE_FETCH=false
# Comma-separated allowlist. Only consulted when BASTION_LIVE_FETCH=true.
BASTION_FETCH_ALLOWLIST=www.cisa.gov,services.nvd.nist.gov,api.first.org
BASTION_FETCH_MAX_BYTES=10485760
BASTION_FETCH_TIMEOUT_SECONDS=20

# --- Per-source feed cache ---
# Integrity-checked (SHA-256), local-only cache of fetched feed bodies. On by
# default. Within the TTL a repeat ingest is served from disk with no network
# request; if a live fetch fails on transport, a stale copy is served as a
# fallback (`bastion forecast ingest --url ... --offline` forces cache-only,
# `--refresh` forces a live fetch). The cache is never a policy bypass — the
# HTTPS + allowlist guard is re-checked on every ingest.
BASTION_FETCH_CACHE=true
BASTION_FETCH_CACHE_TTL_SECONDS=3600
# Relative paths resolve against the Bastion home directory.
BASTION_FETCH_CACHE_DIR=cache/feeds

# --- Active local checks (Assets & Exposure) ---
# Passive-only by default. Active checks are private/loopback-only, opt-in,
# bounded, and logged even when this is true.
BASTION_ACTIVE_CHECKS=false

# --- Custom detection rules ---
# Optional directory of your own detection rule JSON files. Every rule is linted
# and ReDoS-screened on load; accepted rules are stored as DRAFT detections and
# must pass the Detection Validation Range before they are considered validated.
BASTION_RULES_DIR=

# --- AI assistant ---
# Local-first assistant. Disabled by default. Command execution by the
# assistant is separately gated and also disabled by default.
BASTION_AI_ASSISTANT=false
BASTION_AI_COMMAND_EXECUTION=false
# Optional local model endpoint (e.g. an Ollama/llama.cpp server on loopback).
# Cloud endpoints are refused unless BASTION_AI_ALLOW_CLOUD=true is set explicitly.
BASTION_AI_ENDPOINT=
BASTION_AI_ALLOW_CLOUD=false

# --- Logging ---
BASTION_LOG_LEVEL=INFO
